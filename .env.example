# ==========================================
# Required
# ==========================================

# Your EVM wallet private key (for key registration + on-chain deposit)
# IMPORTANT: On mainnet this is a REAL key with REAL funds
WALLET_PRIVATE_KEY=

# ==========================================
# Auto-generated by register-key
# ==========================================

# Ed25519 private key for API signing
# ORDERLY_SECRET=

# Orderly Account ID (derived from wallet address + broker ID)
# ORDERLY_ACCOUNT_ID=

# ==========================================
# Optional
# ==========================================

# Network: "testnet" (default) or "mainnet"
# NETWORK=testnet

# Broker ID (default: woofi_pro)
# BROKER_ID=woofi_pro

# Custom RPC URL for mainnet (defaults to https://arb1.arbitrum.io/rpc)
# Recommended: use a paid provider like Alchemy/Infura for mainnet reliability
# RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
